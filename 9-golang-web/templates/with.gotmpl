<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{.Title}}</title>
</head>
<body>
    <h1>{{.Name}}</h1>
    {{with.Address}}
        <h5>{{.Street}}</h5>
        <h5>{{.City}}</h5>
        <h5>{{.State}}</h5>
        <h5>{{.Zip}}</h5>
    {{end}}
</body>
</html>